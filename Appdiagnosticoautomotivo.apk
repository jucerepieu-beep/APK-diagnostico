<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AutoDX Fácil</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #081c3a;
      color: white;
      min-height: 100vh;
      padding: 20px;
    }

    .container {
      max-width: 950px;
      margin: auto;
    }

    .topo {
      text-align: center;
      margin-bottom: 25px;
    }

    .topo h1 {
      font-size: 38px;
      color: #ff7a00;
      margin-bottom: 10px;
    }

    .topo p {
      color: #d8d8d8;
      font-size: 18px;
    }

    .card {
      background: #10284d;
      border-radius: 20px;
      padding: 25px;
      margin-bottom: 25px;
      box-shadow: 0 0 20px rgba(0,0,0,0.3);
    }

    .card h2 {
      color: #ff7a00;
      margin-bottom: 20px;
      font-size: 24px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 15px;
    }

    input,
    select,
    textarea {
      width: 100%;
      padding: 14px;
      border-radius: 12px;
      border: none;
      outline: none;
      background: #e9eef7;
      font-size: 15px;
    }

    textarea {
      min-height: 120px;
      resize: vertical;
    }

    .sintomas {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 15px;
      margin-top: 15px;
    }

    .sintoma {
      background: #16345f;
      padding: 18px;
      border-radius: 15px;
      cursor: pointer;
      transition: 0.3s;
      border: 2px solid transparent;
      text-align: center;
      font-weight: bold;
    }

    .sintoma:hover {
      transform: scale(1.03);
      border-color: #ff7a00;
    }

    .sintoma.ativo {
      background: #ff7a00;
      color: #081c3a;
    }

    button {
      width: 100%;
      background: #ff7a00;
      color: #081c3a;
      border: none;
      padding: 18px;
      border-radius: 14px;
      font-size: 18px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.3s;
      margin-top: 20px;
    }

    button:hover {
      background: #ff922e;
    }

    .resultado {
      display: none;
    }

    .box {
      background: #16345f;
      border-left: 8px solid #ff7a00;
      padding: 20px;
      border-radius: 15px;
      margin-top: 15px;
    }

    .urgencia {
      padding: 12px;
      border-radius: 10px;
      font-weight: bold;
      margin-top: 10px;
      display: inline-block;
    }

    .alta {
      background: #ff3b30;
      color: white;
    }

    .media {
      background: #ffcc00;
      color: #000;
    }

    .baixa {
      background: #2ecc71;
      color: white;
    }

    .acoes {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 15px;
      margin-top: 20px;
    }

    .acoes button {
      margin-top: 0;
    }

    .alerta {
      margin-top: 25px;
      background: #ffc107;
      color: #000;
      padding: 20px;
      border-radius: 15px;
      font-weight: bold;
      line-height: 1.6;
    }

    .footer {
      text-align: center;
      margin-top: 30px;
      color: #bfbfbf;
      font-size: 14px;
    }

    @media(max-width: 768px) {
      .topo h1 {
        font-size: 30px;
      }
    }
  </style>
</head>
<body>

  <div class="container">

    <div class="topo">
      <h1>AutoDX Fácil</h1>
      <p>Diagnóstico veicular inteligente para pessoas leigas</p>
    </div>

    <div class="card">
      <h2>Dados do Veículo</h2>

      <div class="grid">
        <input type="text" id="marca" placeholder="Marca do veículo">
        <input type="text" id="modelo" placeholder="Modelo do veículo">
        <input type="number" id="ano" placeholder="Ano do veículo">
        <input type="text" id="motor" placeholder="Motorização ex: 1.0 / 1.6 / 2.0">
      </div>
    </div>

    <div class="card">
      <h2>Selecione o Sintoma Principal</h2>

      <div class="sintomas">
        <div class="sintoma" data-sintoma="falhando">Carro falhando</div>
        <div class="sintoma" data-sintoma="naoliga">Não liga</div>
        <div class="sintoma" data-sintoma="esquentando">Superaquecendo</div>
        <div class="sintoma" data-sintoma="fumaca">Saindo fumaça</div>
        <div class="sintoma" data-sintoma="barulho">Barulho estranho</div>
        <div class="sintoma" data-sintoma="vibracao">Vibração excessiva</div>
        <div class="sintoma" data-sintoma="consumo">Consumo alto</div>
        <div class="sintoma" data-sintoma="freio">Problemas no freio</div>
      </div>
    </div>

    <div class="card">
      <h2>Detalhes Adicionais</h2>

      <textarea id="descricao" placeholder="Explique com detalhes o problema do veículo..."></textarea>

      <button onclick="gerarDiagnostico()">Gerar Diagnóstico Inteligente</button>
    </div>

    <div class="card resultado" id="resultado">
      <h2>Resultado do Diagnóstico</h2>

      <div class="box">
        <h3>Diagnóstico Provável</h3>
        <p id="diag"></p>
      </div>

      <div class="box">
        <h3>Nível de Urgência</h3>
        <div id="urgencia"></div>
      </div>

      <div class="box">
        <h3>O que verificar primeiro</h3>
        <p id="verificar"></p>
      </div>

      <div class="box">
        <h3>Estimativa média de custo</h3>
        <p id="custo"></p>
      </div>

      <div class="box">
        <h3>Explicação simples</h3>
        <p id="explicacao"></p>
      </div>

      <div class="acoes">
        <button onclick="baixarPDF()">Baixar PDF</button>
        <button onclick="enviarWhatsApp()">Enviar WhatsApp</button>
        <button onclick="enviarEmail()">Enviar por Email</button>
      </div>

      <div class="alerta">
        ⚠️ AVISO IMPORTANTE: Este diagnóstico é baseado nas informações fornecidas pelo usuário e serve como orientação inicial. Sempre procure uma oficina especializada para confirmação técnica completa.
      </div>
    </div>

    <div class="footer">
      AutoDX Fácil © 2026 — Sistema Inteligente de Diagnóstico Veicular
    </div>

  </div>

  <script>

    let sintomaSelecionado = '';

    const sintomas = document.querySelectorAll('.sintoma');

    sintomas.forEach(item => {
      item.addEventListener('click', () => {

        sintomas.forEach(el => el.classList.remove('ativo'));

        item.classList.add('ativo');

        sintomaSelecionado = item.dataset.sintoma;
      });
    });

    const diagnosticos = {

      falhando: {
        diag: 'Possível falha de ignição, velas gastas, bobina defeituosa ou bicos injetores sujos.',
        urgencia: 'ALTA',
        classe: 'alta',
        verificar: 'Velas, cabos, bobinas e sistema de injeção eletrônica.',
        custo: 'R$ 150 até R$ 1.200',
        explicacao: 'O motor pode estar queimando combustível de forma irregular.'
      },

      naoliga: {
        diag: 'Possível bateria descarregada, motor de partida ou falha elétrica.',
        urgencia: 'ALTA',
        classe: 'alta',
        verificar: 'Bateria, alternador, fusíveis e motor de arranque.',
        custo: 'R$ 120 até R$ 2.000',
        explicacao: 'O sistema elétrico pode não estar conseguindo alimentar o veículo corretamente.'
      },

      esquentando: {
        diag: 'Possível problema no sistema de arrefecimento.',
        urgencia: 'ALTA',
        classe: 'alta',
        verificar: 'Radiador, água, ventoinha, válvula termostática e bomba d’água.',
        custo: 'R$ 200 até R$ 3.500',
        explicacao: 'O motor está trabalhando acima da temperatura ideal.'
      },

      fumaca: {
        diag: 'Possível queima de óleo, mistura rica ou problemas internos no motor.',
        urgencia: 'MÉDIA/ALTA',
        classe: 'media',
        verificar: 'Nível de óleo, junta do cabeçote e sistema de combustível.',
        custo: 'R$ 300 até R$ 8.000',
        explicacao: 'O motor pode estar queimando óleo ou combustível incorretamente.'
      },

      barulho: {
        diag: 'Possível desgaste mecânico ou problemas em suspensão e rolamentos.',
        urgencia: 'MÉDIA',
        classe: 'media',
        verificar: 'Suspensão, rolamentos, correias e escapamento.',
        custo: 'R$ 100 até R$ 2.500',
        explicacao: 'Peças podem estar desgastadas ou com folgas anormais.'
      },

      vibracao: {
        diag: 'Possível desbalanceamento, problemas em pneus ou transmissão.',
        urgencia: 'MÉDIA',
        classe: 'media',
        verificar: 'Pneus, rodas, alinhamento e coxins.',
        custo: 'R$ 80 até R$ 2.000',
        explicacao: 'O veículo pode estar com componentes desalinhados ou desgastados.'
      },

      consumo: {
        diag: 'Possível problema de injeção eletrônica ou sensores.',
        urgencia: 'BAIXA/MÉDIA',
        classe: 'baixa',
        verificar: 'Filtro de ar, velas, sensores e bicos.',
        custo: 'R$ 100 até R$ 1.500',
        explicacao: 'O motor pode estar consumindo mais combustível que o normal.'
      },

      freio: {
        diag: 'Possível desgaste nas pastilhas, discos ou fluido de freio.',
        urgencia: 'ALTA',
        classe: 'alta',
        verificar: 'Pastilhas, discos, fluido e cilindro mestre.',
        custo: 'R$ 150 até R$ 2.000',
        explicacao: 'O sistema de frenagem pode estar comprometido.'
      }

    };

    function gerarDiagnostico() {

      if(sintomaSelecionado === '') {
        alert('Selecione um sintoma principal.');
        return;
      }

      const resultado = diagnosticos[sintomaSelecionado];

      document.getElementById('resultado').style.display = 'block';

      document.getElementById('diag').innerText = resultado.diag;

      document.getElementById('urgencia').innerHTML = `
        <div class="urgencia ${resultado.classe}">
          ${resultado.urgencia}
        </div>
      `;

      document.getElementById('verificar').innerText = resultado.verificar;
      document.getElementById('custo').innerText = resultado.custo;
      document.getElementById('explicacao').innerText = resultado.explicacao;

      document.getElementById('resultado').scrollIntoView({
        behavior: 'smooth'
      });
    }

    function baixarPDF() {
      window.print();
    }

    function enviarWhatsApp() {

      const texto = `Diagnóstico AutoDX Fácil:%0A%0A${document.getElementById('diag').innerText}%0A%0AUrgência: ${document.getElementById('urgencia').innerText}`;

      window.open(`https://wa.me/?text=${texto}`, '_blank');
    }

    function enviarEmail() {

      const assunto = 'Diagnóstico Veicular AutoDX Fácil';

      const corpo = `Diagnóstico:%0A${document.getElementById('diag').innerText}%0A%0AUrgência:%0A${document.getElementById('urgencia').innerText}`;

      window.location.href = `mailto:?subject=${assunto}&body=${corpo}`;
    }

  </script>

</body>
</html>
